import { init, shutdown } from "../src/lib"
import { buildkite_normalize, fixture_raw } from "./helpers"

@complexity(allow)
pipeline default() {
  let token = "test-webhook-token"
  shutdown()
  init({webhook_token: token})
  // build.finished + passed -> build.passed, not a failure.
  let passed = buildkite_normalize(fixture_raw("build_passed", token, "build.finished"))
  assert_eq(passed.type, "event", "passed envelope type")
  assert_eq(passed.event.kind, "build.passed", "passed kind")
  assert_eq(passed.event.signature_status.state, "verified", "passed signed")
  assert_eq(passed.event.signature_status.method, "signature", "passed signature method")
  assert_eq(passed.event.payload.provider, "buildkite", "passed provider")
  assert_eq(passed.event.payload.state, "passed", "passed state")
  assert_eq(passed.event.payload.is_failure, false, "passed not failure")
  assert_eq(
    passed.event.payload.commit_sha,
    "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "passed commit",
  )
  assert_eq(passed.event.payload.branch, "main", "passed branch")
  assert_eq(passed.event.payload.pipeline_slug, "web", "passed pipeline slug")
  assert_eq(passed.event.payload.build_number, 42, "passed build number")
  assert_eq(passed.event.payload.pr_number, nil, "passed has no pr_number")
  assert_eq(passed.event.payload.rerun_handle.org, "acme", "passed rerun org")
  assert_eq(passed.event.payload.rerun_handle["pipeline"], "web", "passed rerun pipeline")
  assert_eq(passed.event.payload.rerun_handle.build_number, 42, "passed rerun build number")
  // build.finished + failed -> build.failed, is_failure true, pr_number from build.pull_request.
  let failed = buildkite_normalize(fixture_raw("build_failed", token, "build.finished"))
  assert_eq(failed.event.kind, "build.failed", "failed kind")
  assert_eq(failed.event.payload.state, "failed", "failed state")
  assert_eq(failed.event.payload.is_failure, true, "failed is_failure")
  assert_eq(
    failed.event.payload.commit_sha,
    "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
    "failed commit",
  )
  assert_eq(failed.event.payload.branch, "feature/login", "failed branch")
  assert_eq(failed.event.payload.pr_number, 137, "failed pr_number from build.pull_request")
  assert_eq(failed.event.payload.build_id, "b4444444-4444-4444-4444-444444444444", "failed build id")
  assert(failed.event.payload.web_url != nil, "failed web_url present")
  // job.finished maps job details and surfaces rerun job_id.
  let job = buildkite_normalize(fixture_raw("job_failed", token, "job.finished"))
  assert_eq(job.event.kind, "job.finished", "job kind")
  assert_eq(job.event.payload.job.id, "j5555555-5555-5555-5555-555555555555", "job id")
  assert_eq(job.event.payload.job.exit_status, 1, "job exit status")
  assert_eq(
    job.event.payload.rerun_handle.job_id,
    "j5555555-5555-5555-5555-555555555555",
    "rerun job id",
  )
  // dedupe key is surfaced and stable on the (pipeline, build, event, state) tuple.
  assert_eq(failed.event.dedupe_key, "buildkite:web:43:build.finished:failed", "dedupe key tuple")
  assert(passed.event.dedupe_key != failed.event.dedupe_key, "distinct dedupe keys")
  shutdown()
}
